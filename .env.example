# ── HTTP server ───────────────────────────────────────────────────────────────
# Port the service listens on.
PORT=8080

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Full DSN including credentials and database name.
# When running locally against the Docker Compose stack use:
#   postgres://postgres:postgres@localhost:5432/rider_assignment?sslmode=disable
# When running inside Docker Compose use:
#   postgres://postgres:postgres@postgres:5432/rider_assignment?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rider_assignment?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
# host:port of the Redis server.
# Docker Compose internal address: redis:6379
REDIS_ADDR=localhost:6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Bootstrap broker address (host:port).
# When running inside Docker Compose use:    kafka:9092
# When connecting to the Docker Compose Kafka from your host machine use:
#   localhost:29092   (mapped via the PLAINTEXT_HOST listener)
KAFKA_BROKER=localhost:29092

# ── Logging ───────────────────────────────────────────────────────────────────
# Minimum log level emitted. One of: debug | info | warn | error
LOG_LEVEL=info
