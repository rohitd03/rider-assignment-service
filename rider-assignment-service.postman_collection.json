                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"pickup_lat\": 12.9716,\n    \"pickup_lng\": 77.5946\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{base_url}}/api/v1/orders",
                    "host": ["{{base_url}}"],
                    "path": ["api", "v1", "orders"]
                }
            },
            "response": []
        },
        {
            "name": "6 · Assign Rider",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test(\"Status code is 2xx\", function () {",
                            "    pm.expect(pm.response.code).to.be.within(200, 299);",
                            "});",
                            "",
                            "pm.test(\"Response is valid JSON\", function () {",
                            "    pm.response.json();",
                            "});",
                            "",
                            "pm.test(\"Order is ASSIGNED and has a rider_id\", function () {",
                            "    var json = pm.response.json();",
                            "    pm.expect(json.status).to.eql(\"ASSIGNED\");",
                            "    pm.expect(json.rider_id).to.be.a(\"string\").and.not.empty;",
                            "});"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [],
