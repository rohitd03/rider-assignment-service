                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"lat\": 12.9720,\n    \"lng\": 77.5950\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{base_url}}/api/v1/riders/{{rider_id}}/location",
                    "host": ["{{base_url}}"],
                    "path": ["api", "v1", "riders", "{{rider_id}}", "location"]
                }
            },
            "response": []
        },
        {
