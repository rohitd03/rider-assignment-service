                            "});",
                            "",
                            "pm.test(\"Response is valid JSON\", function () {",
                            "    pm.response.json();",
                            "});",
                            "",
                            "pm.test(\"Response contains order id\", function () {",
                            "    var json = pm.response.json();",
                            "    pm.expect(json.id).to.be.a(\"string\").and.not.empty;",
                            "    pm.expect(json.status).to.eql(\"CREATED\");",
                            "});"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json",
                        "type": "text"
