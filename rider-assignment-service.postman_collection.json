                },
                "url": {
                    "raw": "{{base_url}}/api/v1/riders/{{rider_id}}/availability",
                    "host": ["{{base_url}}"],
                    "path": ["api", "v1", "riders", "{{rider_id}}", "availability"]
                }
            },
            "response": []
        },
        {
